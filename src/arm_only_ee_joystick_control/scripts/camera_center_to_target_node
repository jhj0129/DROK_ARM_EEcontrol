#!/usr/bin/env python3
import math
import time
import numpy as np

import rclpy
from rclpy.node import Node
from rclpy.qos import qos_profile_sensor_data
from rclpy.time import Time

from sensor_msgs.msg import Image, CameraInfo
from geometry_msgs.msg import PointStamped

import tf2_ros


def quat_rotate(qx, qy, qz, qw, v):
    x, y, z = v

    uvx = qy * z - qz * y
    uvy = qz * x - qx * z
    uvz = qx * y - qy * x

    uuvx = qy * uvz - qz * uvy
    uuvy = qz * uvx - qx * uvz
    uuvz = qx * uvy - qy * uvx

    return (
        x + 2.0 * (qw * uvx + uuvx),
        y + 2.0 * (qw * uvy + uuvy),
        z + 2.0 * (qw * uvz + uuvz),
    )


class CameraCenterToTarget(Node):
    def __init__(self):
        super().__init__("camera_center_to_target_node")

        self.declare_parameter("depth_topic", "/camera/camera/aligned_depth_to_color/image_raw")
        self.declare_parameter("info_topic", "/camera/camera/color/camera_info")
        self.declare_parameter("target_frame", "ARM_BASE_LINK")
        self.declare_parameter("publish_topic", "/ee_obstacle/target_point")

        self.declare_parameter("pixel_u", -1)
        self.declare_parameter("pixel_v", -1)
        self.declare_parameter("patch_radius", 4)

        # Raw depth sanity filter. Real workspace filtering happens after TF.
        self.declare_parameter("raw_depth_min", 0.10)
        self.declare_parameter("raw_depth_max", 3.00)

        # Robot workspace filter.
        # Previous practical max forward reach was about x=0.90 m.
        # We allow +20% margin: 0.90 * 1.20 = 1.08 m.
        self.declare_parameter("arm_x_min", 0.10)
        self.declare_parameter("arm_x_max", 1.08)
        self.declare_parameter("arm_y_abs_max", 0.60)
        self.declare_parameter("arm_z_min", -0.05)
        self.declare_parameter("arm_z_max", 0.90)

        # Safety: default is print only.
        # Set publish_enabled:=true only when you want to send the target.
        self.declare_parameter("publish_enabled", False)
        self.declare_parameter("publish_once", True)
        self.declare_parameter("print_period", 0.8)

        self.depth_topic = self.get_parameter("depth_topic").value
        self.info_topic = self.get_parameter("info_topic").value
        self.target_frame = self.get_parameter("target_frame").value
        self.publish_topic = self.get_parameter("publish_topic").value

        self.pixel_u = int(self.get_parameter("pixel_u").value)
        self.pixel_v = int(self.get_parameter("pixel_v").value)
        self.patch_radius = int(self.get_parameter("patch_radius").value)

        self.raw_depth_min = float(self.get_parameter("raw_depth_min").value)
        self.raw_depth_max = float(self.get_parameter("raw_depth_max").value)

        self.arm_x_min = float(self.get_parameter("arm_x_min").value)
        self.arm_x_max = float(self.get_parameter("arm_x_max").value)
        self.arm_y_abs_max = float(self.get_parameter("arm_y_abs_max").value)
        self.arm_z_min = float(self.get_parameter("arm_z_min").value)
        self.arm_z_max = float(self.get_parameter("arm_z_max").value)

        self.publish_enabled = bool(self.get_parameter("publish_enabled").value)
        self.publish_once = bool(self.get_parameter("publish_once").value)
        self.print_period = float(self.get_parameter("print_period").value)

        self.info = None
        self.last_print = 0.0
        self.already_published = False

        self.tf_buffer = tf2_ros.Buffer()
        self.tf_listener = tf2_ros.TransformListener(self.tf_buffer, self)

        self.pub = self.create_publisher(PointStamped, self.publish_topic, 10)

        self.create_subscription(CameraInfo, self.info_topic, self.info_cb, qos_profile_sensor_data)
        self.create_subscription(Image, self.depth_topic, self.depth_cb, qos_profile_sensor_data)

        self.get_logger().info("camera_center_to_target_node started")
        self.get_logger().info(f"depth_topic     : {self.depth_topic}")
        self.get_logger().info(f"info_topic      : {self.info_topic}")
        self.get_logger().info(f"target_frame    : {self.target_frame}")
        self.get_logger().info(f"publish_topic   : {self.publish_topic}")
        self.get_logger().info(f"publish_enabled : {self.publish_enabled}")
        self.get_logger().info("workspace filter:")
        self.get_logger().info(f"  x: {self.arm_x_min:.2f} ~ {self.arm_x_max:.2f} m")
        self.get_logger().info(f"  y: ±{self.arm_y_abs_max:.2f} m")
        self.get_logger().info(f"  z: {self.arm_z_min:.2f} ~ {self.arm_z_max:.2f} m")

    def info_cb(self, msg):
        self.info = msg

    def depth_cb(self, msg):
        if self.info is None:
            return

        now = time.time()
        if now - self.last_print < self.print_period:
            return
        self.last_print = now

        h, w = msg.height, msg.width

        u = self.pixel_u if self.pixel_u >= 0 else w // 2
        v = self.pixel_v if self.pixel_v >= 0 else h // 2

        if not (0 <= u < w and 0 <= v < h):
            self.get_logger().warn(f"pixel out of image: u={u}, v={v}, image={w}x{h}")
            return

        if msg.encoding == "16UC1":
            depth = np.frombuffer(msg.data, dtype=np.uint16).reshape(h, w).astype(np.float32) * 0.001
        elif msg.encoding == "32FC1":
            depth = np.frombuffer(msg.data, dtype=np.float32).reshape(h, w)
        else:
            self.get_logger().warn(f"unsupported depth encoding: {msg.encoding}")
            return

        r = self.patch_radius
        patch = depth[max(0, v-r):min(h, v+r+1), max(0, u-r):min(w, u+r+1)]

        valid = patch[np.isfinite(patch)]
        valid = valid[(valid >= self.raw_depth_min) & (valid <= self.raw_depth_max)]

        raw_center = float(depth[v, u])

        if valid.size == 0:
            print("----")
            print("[NO TARGET] raw depth out of range")
            print(f"pixel: u={u}, v={v}")
            print(f"raw center depth: {raw_center:.3f} m")
            print(f"accepted raw depth: {self.raw_depth_min:.2f} ~ {self.raw_depth_max:.2f} m")
            return

        z = float(np.median(valid))

        fx = self.info.k[0]
        fy = self.info.k[4]
        cx = self.info.k[2]
        cy = self.info.k[5]

        # camera_color_optical_frame convention:
        # x = image right, y = image down, z = camera forward
        x = (u - cx) * z / fx
        y = (v - cy) * z / fy

        source_frame = msg.header.frame_id if msg.header.frame_id else "camera_color_optical_frame"

        try:
            tf = self.tf_buffer.lookup_transform(
                self.target_frame,
                source_frame,
                Time()
            )
        except Exception as e:
            print("----")
            print(f"[WARN] TF not ready: {self.target_frame} <- {source_frame}")
            print(str(e))
            return

        t = tf.transform.translation
        q = tf.transform.rotation

        rx, ry, rz = quat_rotate(q.x, q.y, q.z, q.w, (x, y, z))

        bx = rx + t.x
        by = ry + t.y
        bz = rz + t.z

        inside_workspace = (
            self.arm_x_min <= bx <= self.arm_x_max and
            -self.arm_y_abs_max <= by <= self.arm_y_abs_max and
            self.arm_z_min <= bz <= self.arm_z_max
        )

        print("----")
        print(f"pixel: u={u}, v={v}")
        print(f"raw center depth: {raw_center:.3f} m")
        print(f"valid median depth: {z:.3f} m")
        print(f"{source_frame}: x={x:.3f}, y={y:.3f}, z={z:.3f}")
        print(f"{self.target_frame}: x={bx:.3f}, y={by:.3f}, z={bz:.3f}")

        if not inside_workspace:
            print("[NO TARGET] outside robot workspace")
            print(f"workspace x: {self.arm_x_min:.2f} ~ {self.arm_x_max:.2f}")
            print(f"workspace y: ±{self.arm_y_abs_max:.2f}")
            print(f"workspace z: {self.arm_z_min:.2f} ~ {self.arm_z_max:.2f}")
            return

        print("[VALID TARGET] inside robot workspace")

        if not self.publish_enabled:
            print("[PRINT ONLY] publish_enabled=false")
            return

        if self.publish_once and self.already_published:
            print("[SKIP] already published once")
            return

        out = PointStamped()
        out.header.stamp = self.get_clock().now().to_msg()
        out.header.frame_id = self.target_frame
        out.point.x = bx
        out.point.y = by
        out.point.z = bz

        self.pub.publish(out)
        self.already_published = True

        print(f"[PUBLISHED] {self.publish_topic}")
        print(f"  x={bx:.3f}, y={by:.3f}, z={bz:.3f}")


def main():
    rclpy.init()
    node = CameraCenterToTarget()

    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        pass

    node.destroy_node()
    if rclpy.ok():
        rclpy.shutdown()


if __name__ == "__main__":
    main()
