  <joint name="JOINT1" type="revolute">
    <origin xyz="0 0 0" rpy="0 -0 0" />
    <parent link="BASE_LINK" />
    <child link="LINK1" />
    <axis xyz="0 0 1" />
    <limit lower="-5.759587" upper="5.759587" effort="35" velocity="1.2" />
    <dynamics damping="2" friction="0.3" />
  </joint>

  <joint name="JOINT2" type="revolute">
    <origin xyz="0 0 0.086" rpy="0 -0 0" />
    <parent link="LINK1" />
    <child link="LINK2" />
    <axis xyz="0 -1 0" />
    <limit lower="-0.5" upper="0.104720" effort="35" velocity="1.2" />
    <dynamics damping="2" friction="0.3" />
  </joint>

